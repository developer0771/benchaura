# ── Core ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
LOG_LEVEL=info

# ── Firebase Admin (server-side) ──────────────────────────────────────────────
# Option A: paste entire service account JSON as a single-line string
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
FIREBASE_PROJECT_ID=benchaura-56750

# Option B: set path to downloaded service account file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# ── LiveKit (SFU — REQUIRED for video/audio) ─────────────────────────────────
# Benchaura routes all video/audio through a LiveKit SFU so rooms scale
# past 8 participants (up to 50 by default). Two ways to get credentials:
#
#   1) LiveKit Cloud (recommended for most cases)
#      • Sign up: https://cloud.livekit.io → Create project
#      • Copy the WebSocket URL (wss://<project>.livekit.cloud)
#      • Copy the API key + secret from Settings → Keys
#
#   2) Self-host
#      • docker run --rm -p 7880:7880 -e LIVEKIT_KEYS=devkey:devsecret \
#          livekit/livekit-server
#      • LIVEKIT_URL=ws://localhost:7880, KEY=devkey, SECRET=devsecret
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio TURN (legacy — only used by the deprecated mesh path) ─────────────
# Safe to leave blank: LiveKit brings its own TURN.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Sentry (optional — error monitoring) ─────────────────────────────────────
# Get from: sentry.io → Create project → Node.js
SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
