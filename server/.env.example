# ── Core ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
LOG_LEVEL=info

# ── Firebase Admin (server-side) ──────────────────────────────────────────────
# Option A: paste entire service account JSON as a single-line string
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
FIREBASE_PROJECT_ID=benchaura-56750

# Option B: set path to downloaded service account file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# ── Twilio TURN (optional but recommended for production) ─────────────────────
# Get from: console.twilio.com → Account → API keys & tokens
# Without this, uses free openrelay.metered.ca TURN (ok for dev)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# ── Sentry (optional — error monitoring) ─────────────────────────────────────
# Get from: sentry.io → Create project → Node.js
SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
