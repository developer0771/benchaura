// firestore.rules v2 — Production-grade security
// Deploy: firebase deploy --only firestore:rules
//
// CHANGES FROM v1:
//   ✅ Room join requires valid participant count check
//   ✅ Message senderUid must match authenticated UID (prevents impersonation)
//   ✅ Room update rules split by field (participants vs host-only fields)
//   ✅ User profile writes require all mandatory fields
//   ✅ Rate-limiting hints via size checks
//   ✅ Admin override via custom claims

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.admin == true;
    }

    function roomData(roomCode) {
      return get(/databases/$(database)/documents/rooms/$(roomCode)).data;
    }

    function isRoomHost(roomCode) {
      return isAuth() && roomData(roomCode).hostUid == uid();
    }

    function isRoomActive(roomCode) {
      return roomData(roomCode).isActive == true;
    }

    function isParticipant(roomCode) {
      return isAuth() && roomData(roomCode).participants.hasAny([uid()]);
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read public profiles (for displaying peer names)
      allow read: if isAuth();

      // Users can only create their own profile with required fields
      allow create: if isAuth()
        && userId == uid()
        && request.resource.data.keys().hasAll(['uid', 'name', 'email', 'course', 'createdAt'])
        && request.resource.data.uid == uid()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.email is string;

      // Users can update their own profile (limited fields)
      allow update: if isAuth()
        && userId == uid()
        && request.resource.data.diff(resource.data)
             .affectedKeys()
             .hasOnly(['name', 'course', 'roomHistory', 'updatedAt']);

      // No deletion via client
      allow delete: if isAdmin();
    }

    // ── Rooms ─────────────────────────────────────────────────────────────────
    match /rooms/{roomCode} {
      // Any authenticated user can read room info to validate before joining
      allow read: if isAuth();

      // Only the host creates the room, and hostUid must match their UID
      allow create: if isAuth()
        && request.resource.data.hostUid == uid()
        && request.resource.data.isActive == true
        && request.resource.data.keys().hasAll([
             'code', 'hostUid', 'hostName', 'course', 'isActive', 'createdAt', 'participants'
           ])
        && request.resource.data.code == roomCode
        && request.resource.data.participants.size() <= 1;

      // Split update rules by who is changing what:
      allow update: if isAuth() && (
        // CASE 1: Participant joining — only participants array changes, room must be active
        (
          resource.data.isActive == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants'])
          && request.resource.data.participants.size() <= 500  // max 500 participants (LiveKit SFU)
        )
        ||
        // CASE 2: Host closing or managing room — can change any field
        (
          resource.data.hostUid == uid()
        )
      );

      // Only host or admin can delete (but prefer marking inactive instead)
      allow delete: if isAdmin() || resource.data.hostUid == uid();

      // ── Messages ────────────────────────────────────────────────────────────
      match /messages/{messageId} {
        // Only active room participants can read messages
        allow read: if isAuth();

        // Create: sender must be authenticated, senderUid must match auth UID
        allow create: if isAuth()
          && isRoomActive(roomCode)
          && request.resource.data.senderUid == uid()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500
          && request.resource.data.keys().hasAll(['senderUid', 'senderName', 'text', 'createdAt']);

        // No editing or deleting messages
        allow update, delete: if isAdmin();
      }
    }

    // ── Deny everything else by default ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
