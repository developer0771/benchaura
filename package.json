{
  "name": "benchaura",
  "private": true,
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=web\"",
    "build": "npm run build --workspace=web",
    "start": "concurrently \"npm run start --workspace=server\" \"npm run start --workspace=web\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
